---
interface Props {
  value?: number;
  showValue?: boolean;
  size?: "sm" | "md";
}

const { value = 0, showValue = false, size = "md" } = Astro.props;
const normalizedValue = Math.min(5, Math.max(0, value));
const fillPercentage = `${(normalizedValue / 5) * 100}%`;
---

<div
  class="inline-flex items-center gap-2"
  role="img"
  aria-label={`评分 ${normalizedValue.toFixed(1)} / 5`}
>
  <span class={`rating-stars ${size === "sm" ? "text-sm" : "text-lg"}`}>
    <span class="rating-stars__base" aria-hidden="true">★★★★★</span>
    <span
      class="rating-stars__fill"
      style={`width: ${fillPercentage}`}
      aria-hidden="true">★★★★★</span
    >
  </span>
  {
    showValue && (
      <span class="text-sm font-bold text-orange-500">
        {normalizedValue.toFixed(1)}
      </span>
    )
  }
</div>

<style>
  .rating-stars {
    position: relative;
    display: inline-block;
    line-height: 1;
    letter-spacing: 0.08em;
  }

  .rating-stars__base {
    color: rgb(156 163 175 / 0.45);
  }

  .rating-stars__fill {
    position: absolute;
    inset: 0 auto 0 0;
    overflow: hidden;
    color: rgb(249 115 22);
    white-space: nowrap;
  }
</style>
