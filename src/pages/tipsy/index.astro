---
import BaseLayout from "@components/base/BaseLayout.astro";
import DrinkCard from "@components/tipsy/DrinkCard.astro";
import LiquidGlass from "@components/common/LiquidGlassLess.astro";
import { getCollection } from "astro:content";

const drinks = (await getCollection("drinks", ({ data }) => !data.draft)).sort(
  (a, b) => {
    const dateA = a.data.tastedAt ?? a.data.createdAt;
    const dateB = b.data.tastedAt ?? b.data.createdAt;
    return (dateB?.getTime() ?? 0) - (dateA?.getTime() ?? 0);
  },
);

const tagCounts = new Map<string, number>();
drinks.forEach((drink) => {
  drink.data.drinkTypes.forEach((tag) => {
    tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
  });
});
const tags = [...tagCounts.entries()].sort(([a], [b]) =>
  a.localeCompare(b, "zh-CN"),
);
---

<BaseLayout title="微醺小记" description="记录杯中风味，也记录与它相遇的时刻。">
  <div class="tipsy-shell">
    <LiquidGlass
      heavy
      containerClass="mb-7 rounded-[30px]"
      wrapperClass="dock overflow-hidden !p-0"
      textClass="relative overflow-hidden p-6 sm:p-9 lg:p-12"
      animation="fadeDown"
    >
      <div
        class="pointer-events-none absolute -right-16 -top-20 h-64 w-64 rounded-full bg-orange-400/20 blur-3xl"
      >
      </div>
      <div
        class="pointer-events-none absolute -bottom-28 left-1/4 h-56 w-56 rounded-full bg-amber-200/20 blur-3xl dark:bg-amber-700/10"
      >
      </div>
      <div class="relative max-w-3xl">
        <p class="mb-3 text-sm font-bold tracking-[0.28em] text-orange-500">
          TIPSY JOURNAL
        </p>
        <h1 class="mb-4 text-4xl font-bold sm:text-5xl">微醺小记</h1>
        <p
          class="max-w-2xl text-base leading-8 text-txt-s dark:text-darkmode-txt-s sm:text-lg"
        >
          记录杯中风味，也记录与它相遇的时刻。酒不只是一种味道，它也收藏天气、谈话与当时的心境。
        </p>
        <div class="mt-6 flex flex-wrap items-center gap-3 text-sm">
          <span
            class="rounded-full bg-orange-500 px-4 py-2 font-bold text-white"
            >{drinks.length} 篇酒记</span
          >
          <span
            class="rounded-full border border-orange-400/30 bg-white/20 px-4 py-2 dark:bg-black/20"
            >{tags.length} 类杯中风景</span
          >
        </div>
      </div>
    </LiquidGlass>

    <section aria-labelledby="tipsy-filter-title">
      <div class="mb-6">
        <div class="mb-3 flex items-center justify-between gap-4">
          <h2 id="tipsy-filter-title" class="text-xl font-bold">按酒类翻阅</h2>
          <p
            id="tipsy-result-count"
            class="text-sm text-gray-600 dark:text-gray-300"
            aria-live="polite"
          >
            共 {drinks.length} 篇
          </p>
        </div>
        <div class="flex flex-wrap gap-2" role="list" aria-label="酒类标签">
          <a
            href="/tipsy"
            class="tipsy-filter is-active"
            data-filter=""
            aria-current="page"
          >
            全部 <span>{drinks.length}</span>
          </a>
          {
            tags.map(([tag, count]) => (
              <a
                href={`/tipsy?tag=${encodeURIComponent(tag)}`}
                class="tipsy-filter"
                data-filter={encodeURIComponent(tag)}
              >
                {tag} <span>{count}</span>
              </a>
            ))
          }
        </div>
      </div>

      {
        drinks.length > 0 ? (
          <>
            <div
              id="tipsy-grid"
              class="grid grid-cols-1 gap-5 sm:grid-cols-2 xl:grid-cols-3"
            >
              {drinks.map((entry) => (
                <DrinkCard entry={entry} />
              ))}
            </div>
            <LiquidGlass
              containerClass="tipsy-empty mt-6 hidden rounded-2xl"
              wrapperClass="dock"
              textClass="p-8 text-center"
              animation="fadeUp"
            >
              <p class="text-4xl" aria-hidden="true">
                🍷
              </p>
              <h2 class="mt-3 text-xl font-bold">这个标签下还没有酒记</h2>
              <p class="mt-2 text-gray-600 dark:text-gray-300">
                换一个标签看看吧。
              </p>
            </LiquidGlass>
          </>
        ) : (
          <LiquidGlass
            heavy
            containerClass="rounded-[28px]"
            wrapperClass="dock"
            textClass="p-10 text-center sm:p-16"
            animation="fadeUp"
          >
            <p class="text-5xl" aria-hidden="true">
              🥂
            </p>
            <h2 class="mt-5 text-2xl font-bold">第一杯还在路上</h2>
            <p class="mt-3 text-gray-600 dark:text-gray-300">
              酒记发布后，会在这里按时间依次出现。
            </p>
          </LiquidGlass>
        )
      }
    </section>
  </div>
</BaseLayout>

<style>
  .tipsy-shell {
    width: calc(100% - 1.5rem);
    max-width: 1300px;
    min-width: 0;
    margin-inline: auto;
  }

  @media (min-width: 1024px) {
    .tipsy-shell {
      width: calc(100% - 4rem);
    }
  }

  .tipsy-filter {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    min-height: 2.5rem;
    border: 1px solid rgb(249 115 22 / 0.24);
    border-radius: 999px;
    padding: 0.45rem 0.9rem;
    color: inherit;
    background: rgb(255 255 255 / 0.2);
    transition: 180ms ease;
  }

  :global(.dark) .tipsy-filter {
    background: rgb(0 0 0 / 0.18);
  }

  .tipsy-filter:hover,
  .tipsy-filter.is-active {
    border-color: rgb(249 115 22 / 0.75);
    color: white;
    background: rgb(249 115 22 / 0.92);
    transform: translateY(-1px);
  }

  .tipsy-filter span {
    min-width: 1.35rem;
    border-radius: 999px;
    padding: 0 0.35rem;
    text-align: center;
    font-size: 0.72rem;
    background: rgb(255 255 255 / 0.2);
  }
</style>

<script>
  function initTipsyFilters() {
    const filters = Array.from(
      document.querySelectorAll<HTMLElement>("[data-filter]"),
    );
    const cards = Array.from(
      document.querySelectorAll<HTMLElement>("[data-drink-card]"),
    );
    const emptyState = document.querySelector<HTMLElement>(".tipsy-empty");
    const resultCount = document.getElementById("tipsy-result-count");

    const applyFilter = (encodedTag: string, updateUrl = false) => {
      let visibleCount = 0;

      cards.forEach((card) => {
        const cardTags = (card.dataset.tags ?? "").split("|").filter(Boolean);
        const visible = !encodedTag || cardTags.includes(encodedTag);
        card.classList.toggle("hidden", !visible);
        if (visible) visibleCount += 1;
      });

      filters.forEach((filter) => {
        const active = (filter.dataset.filter ?? "") === encodedTag;
        filter.classList.toggle("is-active", active);
        if (active) filter.setAttribute("aria-current", "page");
        else filter.removeAttribute("aria-current");
      });

      if (emptyState) {
        emptyState.classList.toggle("hidden", visibleCount !== 0);
      }
      if (resultCount) resultCount.textContent = `共 ${visibleCount} 篇`;

      if (updateUrl) {
        const url = new URL(window.location.href);
        if (encodedTag) {
          url.searchParams.set("tag", decodeURIComponent(encodedTag));
        } else {
          url.searchParams.delete("tag");
        }
        history.replaceState({}, "", `${url.pathname}${url.search}`);
      }
    };

    filters.forEach((filter) => {
      filter.addEventListener("click", (event) => {
        event.preventDefault();
        applyFilter(filter.dataset.filter ?? "", true);
      });
    });

    const initialTag = new URLSearchParams(window.location.search).get("tag");
    applyFilter(initialTag ? encodeURIComponent(initialTag) : "");
  }

  document.addEventListener("astro:page-load", initTipsyFilters);
</script>
